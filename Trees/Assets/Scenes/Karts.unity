    content: "if (name == \"Look\") {\n    look.x += value.y * 0.1\n    look.y += value.x * 0.1\n} else if (name == \"Steer\") {\n    steer = value\n} else if (name == \"Gas\") {\n    gas = value\n} else if (name == \"Break\") {\n    break = value\n} else if (name == \"Handbrake\") {\n    handbrake = value\n} else if (name == \"Respawn\") {\n    respawn = value\n} else if (name == \"Reset\") {\n    reset = value\n}"
